<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>A special question 💌</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Inter:wght@400;500&display=swap');

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --rose: #e8445a;
      --rose-dark: #c0334a;
      --rose-soft: #fce8ec;
      --rose-pale: #fff5f7;
      --text: #1a1a2e;
      --muted: #7a6575;
      --white: #ffffff;
    }

    body {
      min-height: 100vh;
      background: var(--rose-pale);
      font-family: 'Inter', sans-serif;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      position: relative;
    }

    /* Petals */
    .petal {
      position: fixed;
      pointer-events: none;
      font-size: 1.1rem;
      animation: petalFall linear infinite;
      opacity: 0;
      z-index: 0;
    }
    @keyframes petalFall {
      0%   { transform: translateY(-20px) rotate(0deg); opacity: 0.7; }
      100% { transform: translateY(110vh) rotate(360deg); opacity: 0; }
    }

    /* Card */
    .card {
      background: var(--white);
      border-radius: 24px;
      padding: 3rem 2.5rem 2.5rem;
      max-width: 440px;
      width: calc(100% - 2rem);
      text-align: center;
      position: relative;
      z-index: 10;
      box-shadow: 0 8px 48px rgba(232, 68, 90, 0.10), 0 1px 4px rgba(0,0,0,0.06);
    }

    .card-icon {
      font-size: 3.2rem;
      margin-bottom: 1.2rem;
      display: block;
      animation: pulse 2s ease-in-out infinite;
    }
    @keyframes pulse {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.12); }
    }

    .from-name {
      font-family: 'Playfair Display', serif;
      font-style: italic;
      font-size: 13px;
      color: var(--rose);
      letter-spacing: 0.08em;
      margin-bottom: 0.6rem;
      text-transform: lowercase;
    }

    .question {
      font-family: 'Playfair Display', serif;
      font-size: 28px;
      font-weight: 600;
      color: var(--text);
      line-height: 1.35;
      margin-bottom: 0.75rem;
    }

    .subtitle {
      font-size: 14px;
      color: var(--muted);
      line-height: 1.6;
      margin-bottom: 2.2rem;
    }

    /* YES button */
    .btn-yes {
      display: block;
      width: 100%;
      background: var(--rose);
      color: var(--white);
      border: none;
      border-radius: 14px;
      padding: 16px;
      font-family: 'Inter', sans-serif;
      font-size: 17px;
      font-weight: 500;
      cursor: pointer;
      letter-spacing: 0.02em;
      transition: background 0.18s, transform 0.12s;
      margin-bottom: 1rem;
    }
    .btn-yes:hover { background: var(--rose-dark); transform: scale(1.03); }
    .btn-yes:active { transform: scale(0.98); }

    /* NO button container */
    .no-wrap {
      position: relative;
      height: 52px;
      width: 100%;
    }

    .btn-no {
      position: absolute;
      background: transparent;
      color: var(--muted);
      border: 1px solid #e0d0d5;
      border-radius: 10px;
      padding: 10px 26px;
      font-family: 'Inter', sans-serif;
      font-size: 14px;
      cursor: pointer;
      white-space: nowrap;
      transition: transform 0.08s;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%);
    }

    .try-msg {
      font-size: 12px;
      color: #c0a0a8;
      margin-top: 1rem;
      min-height: 18px;
    }

    /* SUCCESS */
    .success-screen {
      display: none;
      flex-direction: column;
      align-items: center;
    }

    .confetti-emoji {
      font-size: 3.5rem;
      animation: bounce 0.6s ease infinite alternate;
    }
    @keyframes bounce {
      from { transform: translateY(0); }
      to   { transform: translateY(-10px); }
    }

    .success-title {
      font-family: 'Playfair Display', serif;
      font-size: 28px;
      font-weight: 600;
      color: var(--text);
      margin: 1rem 0 0.5rem;
      line-height: 1.3;
    }

    .success-sub {
      font-size: 14px;
      color: var(--muted);
      line-height: 1.7;
      margin-bottom: 1.8rem;
    }

    .reel-btn {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
      padding: 13px 28px;
      border-radius: 14px;
      font-family: 'Inter', sans-serif;
      font-size: 14px;
      font-weight: 500;
      color: #fff;
      background: linear-gradient(135deg, #f9a825 0%, #e64a19 40%, #d81b60 70%, #8e24aa 100%);
      transition: opacity 0.18s, transform 0.12s;
    }
    .reel-btn:hover { opacity: 0.88; transform: scale(1.03); }

    .reel-btn svg { flex-shrink: 0; }
  </style>
</head>
<body>

<div class="card" id="proposalCard">
  <span class="card-icon">💌</span>
  <p class="from-name">a message from suraj</p>
  <h1 class="question">Will you be my girlfriend?&nbsp;🌹</h1>
  <p class="subtitle">You make every ordinary moment feel like something out of a movie. So… what do you say?</p>

  <button class="btn-yes" onclick="sayYes()">Yes, of course! 💕</button>

  <div class="no-wrap">
    <button class="btn-no" id="noBtn" onclick="runAway()">No 🙈</button>
  </div>

  <p class="try-msg" id="tryMsg"></p>
</div>

<div class="card success-screen" id="successCard">
  <span class="confetti-emoji">🎉</span>
  <h1 class="success-title">She said YES! 🥰</h1>
  <p class="success-sub">Suraj, you did it!<br>This is just the beginning of something beautiful. 💖</p>
  <a class="reel-btn" href="https://www.instagram.com/reels/" target="_blank" rel="noopener">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
      <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
      <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
    </svg>
    Watch our special reel
  </a>
</div>

<script>
  // Floating petals
  const petals = ['🌸','🌺','🌷','💗','✨','💖'];
  for (let i = 0; i < 20; i++) {
    const p = document.createElement('div');
    p.className = 'petal';
    p.textContent = petals[Math.floor(Math.random() * petals.length)];
    p.style.left = Math.random() * 100 + 'vw';
    p.style.fontSize = (0.8 + Math.random() * 0.8) + 'rem';
    p.style.animationDuration = (6 + Math.random() * 8) + 's';
    p.style.animationDelay = (Math.random() * 8) + 's';
    document.body.appendChild(p);
  }

  // NO button escape
  let noCount = 0;
  const noBtn = document.getElementById('noBtn');
  const tryMsg = document.getElementById('tryMsg');
  const msgs = [
    "Oops, try again! 😏",
    "Nope, that's not an option 😄",
    "Come on… you know the answer 😉",
    "That button doesn't work here 😂",
    "Just press YES already! 🥺",
    "Still? Really? 😭",
  ];

  function runAway() {
    noCount++;
    const card = document.getElementById('proposalCard');
    const cardW = card.offsetWidth - 56;
    const cardH = 52;
    const btnW = noBtn.offsetWidth;
    const btnH = noBtn.offsetHeight;
    const x = Math.random() * (cardW - btnW);
    const y = Math.random() * (cardH - btnH);
    noBtn.style.left = x + 'px';
    noBtn.style.top = y + 'px';
    noBtn.style.transform = 'none';
    tryMsg.textContent = msgs[Math.min(noCount - 1, msgs.length - 1)];
  }

  function sayYes() {
    document.getElementById('proposalCard').style.display = 'none';
    const s = document.getElementById('successCard');
    s.style.display = 'flex';
    spawnCelebration();
  }

  function spawnCelebration() {
    const extras = ['❤️','💕','💖','💗','🌹','✨','🎊','🎉'];
    for (let i = 0; i < 30; i++) {
      const p = document.createElement('div');
      p.className = 'petal';
      p.textContent = extras[Math.floor(Math.random() * extras.length)];
      p.style.left = Math.random() * 100 + 'vw';
      p.style.fontSize = (1 + Math.random() * 1.2) + 'rem';
      p.style.animationDuration = (3 + Math.random() * 5) + 's';
      p.style.animationDelay = (Math.random() * 2) + 's';
      document.body.appendChild(p);
    }
  }
</script>
</body>
</html>
